{
  "input_text": "The process that determines whether a potential donor is eligible for blood donation",
  "requirements": [
    "receive_exist(tree, 'donorInfo')",
    "leads_to(tree, 'register donor', 'complete questionnaire')",
    "executed_by(tree, 'perform medical check', 'medicalStaff')",
    "condition_eventually_follows(tree, 'isEligible == true', 'collect blood')",
    "condition_eventually_follows(tree, 'isEligible == false', 'notify deferral')",
    "data_leads_to_absence(tree, 'hemoglobinLevel < 12.5', 'collect blood')",
    "precedence(tree, 'collect blood', 'perform medical check')",
    "executed_by(tree, 'collect blood', 'phlebotomist')",
    "min_time_between(tree, 'collect blood', 'End Activity', 900)",
    "failure_eventually_follows(tree, 'store donation record', 'retry storage')"
  ]
}