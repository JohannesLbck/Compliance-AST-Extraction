{
  "requirements": [
    "exists(tree, 'obtain respondent bank report')",
    "exists(tree, 'analyze respondent bank report')",
    "leads_to(tree, 'obtain respondent bank report', 'analyze respondent bank report')",
    "receive_exist(tree, 'respondentBankReport')",
    "condition_eventually_follows(tree, 'respondentBankEvaluationFailed == true', 'add to black list')",
    "data_leads_to_absence(tree, 'riskLevel != \"low\"', 'open account')",
    "condition_eventually_follows(tree, 'isFirstTimeDealWithRespondentBank == true', 'conduct advanced due diligence study')",
    "data_leads_to_absence(tree, 'respondentBankRating == \"rejected\"', 'open account')",
    "data_leads_to_absence(tree, 'respondentBankCertificateValid == false', 'open account')"
  ]
}