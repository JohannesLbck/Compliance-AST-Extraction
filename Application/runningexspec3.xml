<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<bpmSpecification>
    <elementGroups/>
    <specificationSets>
        <specificationSet>
            <conditions/>
            <specifications>
                <specification id="R1" type="Rule1TimeoutIfNoOrderInfoTight">
                    <inputElements>
                        <inputElement target="req">t1</inputElement>
                        <inputElement target="x">t3</inputElement>
                        <inputElement target="y">t2</inputElement>
                    </inputElements>
                </specification>
            </specifications>
        </specificationSet>
        <specificationSet>
            <conditions/>
            <specifications>
                <specification id="R2" type="Rule2ManualReviewAfterAutoFailureTight">
                    <inputElements>
                        <inputElement target="f">t5</inputElement>
                        <inputElement target="m">t6</inputElement>
                        <inputElement target="a">t7</inputElement>
                        <inputElement target="r">t8</inputElement>
                    </inputElements>
                </specification>
            </specifications>
        </specificationSet>
        <specificationSet>
            <conditions/>
            <specifications>
                <specification id="R3" type="Rule3AcceptOrRejectBeforeEndTight">
                    <inputElements>
                        <inputElement target="z">p9</inputElement>
                        <inputElement target="a">t7</inputElement>
                        <inputElement target="r">t8</inputElement>
                    </inputElements>
                </specification>
            </specifications>
        </specificationSet>
        <specificationSet>
            <conditions/>
            <specifications>
                <specification id="R4" type="Rule4NotifyCustomerAfterDecision">
                    <inputElements>
                        <inputElement target="a">t7</inputElement>
                        <inputElement target="r">t8</inputElement>
                        <inputElement target="c">t11</inputElement>
                        <inputElement target="j">t10</inputElement>
                    </inputElements>
                </specification>
            </specifications>
        </specificationSet>
    </specificationSets>
    <specificationTypes>
        <specificationType id="Rule1TimeoutIfNoOrderInfoTight">
            <inputs>
                <input type="or">req</input>
                <input type="or">x</input>
                <input type="or">y</input>
            </inputs>
            <formulas>
                <formula language="CTLSPEC">AG(req -&gt; A[!x U (x | y)])</formula>
            </formulas>
        </specificationType>
        <specificationType id="Rule2ManualReviewAfterAutoFailureTight">
            <inputs>
                <input type="or">f</input>
                <input type="or">m</input>
                <input type="or">a</input>
                <input type="or">r</input>
            </inputs>
            <formulas>
                <formula language="CTLSPEC">AG(f -&gt; A[!a U m])</formula>
            </formulas>
        </specificationType>
        <specificationType id="Rule3AcceptOrRejectBeforeEndTight">
            <inputs>
                <input type="or">z</input>
                <input type="or">a</input>
                <input type="or">r</input>
            </inputs>
            <formulas>
                <formula language="CTLSPEC">AG((a | r) -&gt; AF z) &amp; AG !(a &amp; r)</formula>
            </formulas>
        </specificationType>
        <specificationType id="Rule4NotifyCustomerAfterDecision">
            <inputs>
                <input type="or">a</input>
                <input type="or">r</input>
                <input type="or">c</input>
                <input type="or">j</input>
            </inputs>
            <formulas>
                <formula language="CTLSPEC">AG(a -&gt; A[!r U c]) &amp; AG(r -&gt; A[!a U j])</formula>
            </formulas>
        </specificationType>
    </specificationTypes>
</bpmSpecification>
